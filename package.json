{
  "name": "thrust",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "db:update": "dotenv -e .env.local -- tsx scripts/update-db.ts",
    "db:check": "dotenv -e .env.local -- tsx scripts/check-db.ts"
  },
  "overrides": {
    "react-is": "^19.0.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@tremor/react": "^3.18.7",
    "bcryptjs": "^3.0.2",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.2",
    "iron-session": "^8.0.4",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
